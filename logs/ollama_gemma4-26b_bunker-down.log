        self.entities = self_entities
        self.spawn_timer = 0
        self.difficulty = 60 # frames between spawns

    def run(self):
        pygame.init()
        self.screen = pygame.display.set_mode((1280, 720))
        clock = pygame.time.Clock()
        
        while self.running:
            dt = clock.tick(60)
            self.handle_events()
            self.update(dt)
            self.draw()

    def handle_events(self):
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                self.running = False
            if event.type == pygame.KEYDOWN:
                if self.mode != "PLAY" and event.key == pygame.K_SPACE:
