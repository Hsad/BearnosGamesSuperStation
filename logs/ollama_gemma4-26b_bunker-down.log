                    if z.distance_to(pygame.Vector2(t['pos'])) < 30:
                        self.entities['particles'].append({'pos': pygame.Vector2(z), 'life': 30, 'color': t['color']})
                        # Damage zombie logic would go here
                        if random.random() < 0.05: # slow death
                            self.entities['z_to_remove'].append(z) 
            
            # Update particles
            for p in self.entities['particles'][:]:
                p['life'] -= 1
                if p['life'] <= 0: self.entities['particles'].remove(p)

    def draw(self):
        self.screen.fill((30, 30, 30))
        
        if self.mode == "MENU":
            self.draw_text("DEFENSE PROTOCOL", 1280, 720, 80)
            self.draw_text("Press SPACE to Start", 1280, 720, 40)
        elif self.mode == "PLAY":
