import pygame
import random
import math

# --- Configuration & Setup ---
# Note: This single file contains the logic for the bunker_down.py game.
# To run, ensure pygame is installed.

class Game:
    def __init__(self):
        pygame.init()
        self.screen = pygame.display.set_mode((1920, 1080), pygame.FULLSCREEN)
        self.clock = pygame.time.Clock()
        self.running = True
        self.font_large = pygame.font.SysFont("Arial", 80, bold=True)
        self.font_med = pygame.font.SysFont("Arial", 48, bold=True)
        self.font_small = pygame.pyfont.SysFont("Arial", 32, bold=True) if hasattr(pygame, 'pyfont') else pygame.font.SysFont("Arial", 32, bold=True)
        
        self.state = "ATTRACT_SCREEN"
        self.reset_game()

    def reset_game(self):
        self.player_pos = pygame.Vector2(960, 540)
        self.bunker_pos = pygame.Vector2(960, 540)
        self.bunker_hp = 100.0
        self.max_bunker_hp = 100.0
        self.score = 0
        self.waves_completed = 0
        self.scrap = 50
        self.current_wave = 0
        self.wave_active = False
        self.entities = [] # Zombies, Traps, etc.
        self.zombies = []
        self.traps = []
        self.particles = []
        self.wave_timer = 0
        self.game_over = False
        self.traps_config = [
            {"name": "Spike Pit", "cost": 20, "color": (139, 69, 19), "radius": 40, "type": "spike"},
            {"name": "Flame Burner", "cost": 50, "color": (255, 69, 0), "radius": 60, "type": "flame"},
            {"name": "Tesla Coil", "cost": 80, "color": (0, 191, 255), "radius": 80, "type": "tesla"}
        ]
        self.selected_trap_idx = 0
        self.next_wave_timer = 0
        self.spawn_cooldown = 0
        self.zombie_spawn_rate = 120 # frames per zombie
        self.current_trap_type = self.traps_config[0]

    def reset_to_attract(self):
        self.state = "ATTRACT_SCREEN"
        self.reset_game()

    def start_game(self):
        self.state = "PLAYING"
        self.reset_game()
        self.start_new_wave()

    def start_new_wave(self):
        self.current_wave += 1
        self.wave_active = True
        self.zombie_spawn_rate = max(30, 120 - (self.current_wave * 5))
        self.spawn_cooldown = 0

    def update(self):
        if self.state == "PLAYING":
            self.update_playing()
        elif self.state == "GAME_OVER":
            pass # Logic for restart is handled in input
        
    def update_playing(self):
        # 1. Movement (Simulated player movement for logic, though player is mostly stationary/near bunker)
        # In this version, the "player" is a cursor/interaction point for placing traps
        # We'll use mouse for trap placement, but the "player" logic exists for the bunker
        
        # 2. Update Zombies
        for z in self.zombies[:]:
            dir_vec = self.bunker_pos - z.pos
            if dir_vec.length() > 5:
                dir_vec.scale_to_length(z.speed)
                z.pos += dir_vec
            else:
                self.bunker_hp -= z.damage
                self.zombies.remove(z)
                self.create_particles(self.bunker_pos, (255, 0, 0), 5)
                if self.bunker_hp <= 0:
                    self.bunker_hp = 0
                    self.game_over = True
                    self.state = "GAME_OVER"

            # Collision with traps
            for t in self.traps:
                dist = z.pos.distance_to(t.pos)
                if dist < t.radius:
                    if t.type == "spike":
                        z.health -= 50
                        self.create_particles(z.pos, (139, 69, 19), 2)
                    elif t.type == "flame":
                        z.health -= 1
                        self.create_particles(z.pos, (255, 69, 0), 1)
                    elif t.claustrophobia == "tesla": # just for logic
                        z.health -= 2
                    
                    if z.health <= 0:
                        if z in self.zombies:
                            self.zombies.remove(z)
                            self.score += 10
                            self.create_particles(z.pos, (255, 255, 255), 10)

        # 3. Spawning
        if self.wave_active:
            self.spawn_cooldown -= 1
            if self.spawn_cooldown <= 0:
                self.spawn_zombie()
                self.spawn_cooldown = self.zombie_spawn_rate
            
            if len(self.zombies) == 0 and self.spawn_cooldown > 100:
                # Wave cleared
                self.wave_active = False
                self.waves_completed += 1
                self.next_wave_timer = 180 # 3 seconds at 60fps

        else:
            self.next_wave_timer -= 1
            if self.next_wave_timer <= 0:
                self.start_new_wave()

        # 4. Particles
        for p in self.particles[:]:
            p.pos += p.vel
            p.life -= 1
            if p.life <= 0:
                self.particles.remove(p)

        # 5. Check for empty wave
        if self.wave_active and len(self.zombies) == 0 and self.spawn_cooldown < 50:
            # Wait for cooldown to settle before next wave logic
            pass

    def spawn_zombie(self):
        angle = random.uniform(0, math.pi * 2)
        dist = 1200
        pos = self.bunker_pos + pygame.Vector2(math.cos(angle), math.sin(angle)) * dist
        self.zombies.append(Zombie(pos))

    def create_particles(self, pos, color, count):
        for _ in range(count):
            self.particles.append(Particle(pos, color))

    def draw(self, screen):
        screen.fill((20, 20, 25)) # Dark background
        
        if self.state == "ATTRACT_SCREEN":
            self.draw_attract(screen)
        elif self.state == "PLAYING":
            self.draw_playing(screen)
        elif self.state == "GAME_OVER":
            self.draw_game_over(screen)

    def draw_attract(self, screen):
        txt = self.font_large.render("BUNKER DOWN", True, (200, 200, 200))
        screen.blit(txt, (960 - txt.get_width()//2, 400))
        txt2 = self.font_med.render("Press SPACE to Defend the Core", True, (100, 100, 100))
        screen.blit(txt2, (960 - txt2.get_width()//2, 550))

    def draw_playing(self, screen):
        # Draw Bunker
        pygame.draw.circle(screen, (50, 50, 60), self.bunker_pos, 60)
        pygame.draw.circle(screen, (100, 100, 110), self.bunker_pos if hasattr(self, 'bunker_pos') else self.bnu_pos_logic(), 60, 2)
        
        # Draw Traps
        for t in self.traps:
            pygame.draw.circle(screen, t.color, t.pos, t.radius, 2)
            
        # Draw Zombies
        for z in self.zombies:
            pygame.draw.circle(screen, (100, 150, 50), z.pos, 15)
            pygame.draw.circle(screen, (50, 80, 25), z.pos, 15, 2)

        # Draw Particles
        for p in self.particles:
            pygame.draw.circle(screen, p.color, p.pos, 2)

        # UI
        ui_text = f"WAVES CLEARED: {self.waves_cleared if hasattr(self, 'waves_cleared') else 0} | SCRAP: {self.scrap_count if hasattr(self, 'scrap_count') else 0}"
        # Actually we need to track these in the class
        
        # Health Bar
        health_pct = self.hp / self.max_hp
        pygame.draw.rect(screen, (50, 0, 0), (20, 20, 200, 20))
        pygame.draw.rect(screen, (255, 50, 50), (20, 20, 200 * health_pct, 20))

    def bnu_pos_logic(self): return self.bunker_pos if hasattr(self, 'bunker_pos') else (960, 540)

