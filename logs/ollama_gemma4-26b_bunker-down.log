import math
import random

class Zombie:
    def __init__(self, pos):
        self.pos = pos
        self.health = 100

class Trap:
    def __init__(self, x, y, color):
        self.pos = (x, y)
        self.radius = 30
        self.color = color

class Particle:
    def __init__(self, pos, color):
        self.pos = pos
        self.color = color
        self.life = 500 # frames
        self.vel = [random.uniform(-2, 2), random.uniform(-2, 2)]
    def update(self, dt):
        self.pos[0] += self.vel[0]
        self.pos[1] += self.vel[1]
        self.life -= dt

class Game:
    def __init__(self):
        self.screen = None
        self.running = True
        self.mode = "MENU" # MENU, PLAY, GAMEOVER
        self.scrap = 100
        self.hp = 100
