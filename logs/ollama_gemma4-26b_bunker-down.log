        self.difficulty = 60

    def add_trap(self):
        # Simplified: add trap at random location
        x = random.randint(100, 1100)
        y = random.randint(100, 600)
        self.entities['traps'].append({'pos': (x, y), 'color': (0, 255, 0)})

    def update(self, dt):
        if self.mode == "PLAY":
            # Spawning
            self.spawn_timer += dt
            if self.spawn_timer >= self.difficulty:
                self.spawn_timer = 0
                self.entities['zombies'].append(pygame.Vector2(random.randint(0, 1280), random.randint(0, 720)))
                self.difficulty = max(10, self.difficulty * 0.99)

            # Update Zombies
            target = pygame.Vector2(640, 360)
            for z in self.entities['zombies'][:]:
                direction = (target - z).normalize()
                z += direction * 1.5
                
                # Check collision with base
                if z.distance_to(target) < 50:
